                        c5.106,0,9.246,4.14,9.246,9.246v15.655c10.497-15.753,26.097-27.912,59.312-27.912c73.552,0,73.131,68.716,73.131,106.472
                        L341.91,330.654L341.91,330.654z"/>
                </svg>
            </a>
            </li>
        </ul>
    </section>
}


templ not_found() {
    <section class="min-h-screen w-full flex flex-col items-center justify-center text-center font-['Jersey_10'] text-[var(--text_1)]/82">
        <p class="text-[90px]">404</p>
        <h2 class="text-2xl mt-4">Still working on this page. Come back soon!</h2>
    </section>
}


